{
  "name": "toronto-monitor",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Real-time Toronto intelligence dashboard + per-business AI agent (transit, traffic, weather, 311, permits, events, demographics)",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:ml": "bash scripts/run-ml.sh",
    "dev:parakeet": "bash scripts/run-parakeet.sh",
    "dev:all": "concurrently -n web,api,ml,asr -c cyan,magenta,yellow,green \"npm:dev\" \"npm:dev:server\" \"npm:dev:ml\" \"npm:dev:parakeet\"",
    "build": "tsc && vite build",
    "start:server": "SERVE_STATIC=1 tsx server/index.ts",
    "start": "npm run build && concurrently -n api,ml,asr -c magenta,yellow,green \"npm:start:server\" \"npm:dev:ml\" \"npm:dev:parakeet\"",
    "preview": "vite preview",
    "gen:dataset": "tsx scripts/gen-forecast-dataset.ts",
    "snapshot": "tsx scripts/snapshot-logger.ts",
    "backfill": "tsx scripts/backfill_snapshots.ts",
    "gen:bizdata": "tsx scripts/gen_business_data.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "setup:gpu": "bash scripts/setup-gpu.sh",
    "gx10:nemotron": "bash scripts/gx10-nemotron.sh",
    "agent:nemotron": "bash scripts/run-nemotron-agent.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/three": "^0.184.1",
    "better-sqlite3": "^11.8.1",
    "gridstack": "^12.6.0",
    "gsap": "^3.15.0",
    "hono": "^4.6.14",
    "lenis": "^1.3.23",
    "maplibre-gl": "^5.16.0",
    "preact": "^10.25.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
